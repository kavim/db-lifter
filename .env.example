# Copy to .env and adjust (never commit .env)
DB_LIFT_FILE=./path/to/dump.sql
DB_LIFT_CONTAINER=mysql-container-name
DB_LIFT_USER=root
DB_LIFT_PASSWORD=
DB_LIFT_DATABASE=my_app
# Optional: set to true or 1 to drop/recreate DB (destructive)
# DB_LIFT_RECREATE=true
# Optional: plain logs instead of TUI
# DB_LIFT_NO_TUI=true
